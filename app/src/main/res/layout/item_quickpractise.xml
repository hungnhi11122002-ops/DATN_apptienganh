<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="180dp"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="15dp"
    android:layout_marginVertical="5dp"
    android:background="@drawable/bg_trang"
    android:orientation="horizontal"
    android:padding="10dp">

    <ImageView
        android:id="@+id/imgPractise"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:scaleType="centerCrop"
        android:src="@drawable/family" />

    <LinearLayout
        android:id="@+id/khung1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_practise_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Từ vựng"
            android:textColor="@color/stork_blue_dark"
            android:textSize="20sp"
            android:textStyle="bold"></TextView>

        <TextView
            android:id="@+id/tv_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Học từ vựng mỗi ngày"
            android:textColor="@color/stork_blue_dark"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            ></TextView>
    </LinearLayout>
</LinearLayout>